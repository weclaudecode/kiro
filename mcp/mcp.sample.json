{
  "_install_path": "~/.kiro/settings/mcp.json  OR  <project>/.kiro/settings/mcp.json",
  "_doc": "MCP server registry for kiro-cli. SECRETS: never hardcode — use ${ENV_VAR} placeholders, populate the env via direnv (project) or ~/.config/claude/secrets.env (global). Workspace mcp.json overrides global on conflict.",
  "mcpServers": {
    "aws-api": {
      "command": "uvx",
      "args": ["awslabs.aws-api-mcp-server"],
      "env": {
        "AWS_REGION": "${AWS_REGION}",
        "AWS_PROFILE": "${AWS_PROFILE}"
      },
      "disabled": false,
      "autoApprove": ["call_aws"],
      "timeout": 120000
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "env": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      },
      "disabled": false,
      "autoApprove": ["resolve-library-id", "get-library-docs"],
      "timeout": 60000
    },
    "gitlab": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-gitlab"],
      "env": {
        "GITLAB_PERSONAL_ACCESS_TOKEN": "${GITLAB_TOKEN}",
        "GITLAB_API_URL": "${GITLAB_API_URL}"
      },
      "disabled": false,
      "autoApprove": [],
      "timeout": 60000
    },
    "terraform": {
      "command": "uvx",
      "args": ["awslabs.terraform-mcp-server"],
      "env": {},
      "disabled": false,
      "autoApprove": [],
      "timeout": 60000
    },
    "aws-pricing": {
      "_doc": "AWS list/unit pricing for cost ESTIMATES. All pricing API calls are FREE. Read-only.",
      "command": "uvx",
      "args": ["awslabs.aws-pricing-mcp-server@latest"],
      "env": {
        "AWS_REGION": "${AWS_REGION}",
        "AWS_PROFILE": "${AWS_PROFILE}",
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "disabled": false,
      "autoApprove": ["get_pricing", "get_pricing_service_codes", "get_pricing_service_attributes", "get_pricing_attribute_values", "generate_cost_report"],
      "timeout": 60000
    },
    "cost-explorer": {
      "_doc": "ACTUAL AWS spend via Cost Explorer. WARNING: each Cost Explorer API request bills $0.01. Read-only but PAID. Ships disabled — set disabled:false to opt in. Keep autoApprove EMPTY so every billable call prompts.",
      "command": "uvx",
      "args": ["awslabs.cost-explorer-mcp-server@latest"],
      "env": {
        "AWS_REGION": "${AWS_REGION}",
        "AWS_PROFILE": "${AWS_PROFILE}",
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "disabled": true,
      "autoApprove": [],
      "timeout": 120000
    }
  }
}
